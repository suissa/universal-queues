{
  "name": "@suissa/universal-queues",
  "version": "1.0.0",
  "description": "Factory universal para mensageria (RabbitMQ, Kafka, SQS) para sistemas distribuídos.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --config jest.config.ts",
    "prepare": "npm run build",
    "run:rust": "npm run nats:rust:build && cargo run --manifest-path servers/nats-rust/Cargo.toml --",
    "run:rust:wasm": "npm run nats:rust:wasm",
    "run:zig": "npm run nats:zig:build && servers/nats-zig/nats-zig",
    "run:jai": "npm run nats:jai:build && servers/nats-jai/server",
    "run:benchmark": "node scripts/benchmark-nats-servers.mjs",
    "nats:rust:build": "cargo build --manifest-path servers/nats-rust/Cargo.toml",
    "nats:rust:start": "cargo run --manifest-path servers/nats-rust/Cargo.toml --",
    "nats:rust:test": "cargo test --manifest-path servers/nats-rust/Cargo.toml && node scripts/smoke-nats-server.mjs --port 44222 -- cargo run --manifest-path servers/nats-rust/Cargo.toml -- 44222",
    "nats:rust:wasm": "rustup target add wasm32-wasip1 && cargo build --manifest-path servers/nats-rust/Cargo.toml --target wasm32-wasip1 --bin nats-rust && node scripts/run-nats-rust-wasm.mjs",
    "nats:zig:build": "zig build-exe servers/nats-zig/server.zig -femit-bin=servers/nats-zig/nats-zig",
    "nats:zig:start": "zig run servers/nats-zig/server.zig --",
    "nats:zig:test": "node scripts/smoke-nats-server.mjs --port 44223 -- zig run servers/nats-zig/server.zig -- 44223",
    "nats:jai:build": "cd servers/nats-jai && jai server.jai",
    "nats:jai:start": "servers/nats-jai/server",
    "nats:jai:test": "npm run nats:jai:build && node scripts/smoke-nats-server.mjs --port 44224 -- servers/nats-jai/server 44224",
    "nats:go:build": "cd servers/nats-go && go build -o nats-go .",
    "nats:go:start": "servers/nats-go/nats-go",
    "nats:c:build": "gcc -std=gnu11 -O2 -Wall -Wextra -pthread -o servers/nats-c/nats-c servers/nats-c/server.c",
    "nats:c:start": "servers/nats-c/nats-c",
    "nats:cpp:build": "g++ -std=c++17 -O2 -Wall -Wextra -o servers/nats-cpp/nats-cpp servers/nats-cpp/server.cpp",
    "nats:cpp:start": "servers/nats-cpp/nats-cpp",
    "nats:haskell:build": "ghc -threaded -O2 servers/nats-haskell/Main.hs -o servers/nats-haskell/nats-haskell",
    "nats:haskell:start": "servers/nats-haskell/nats-haskell",
    "nats:odin:build": "odin build servers/nats-odin -out:servers/nats-odin/nats-odin",
    "nats:odin:start": "servers/nats-odin/nats-odin",
    "nats:curry:build": "pakcs :load servers/nats-curry/server.curry :save nats-curry",
    "nats:curry:start": "servers/nats-curry/nats-curry",
    "nats:mojo:build": "mojo build servers/nats-mojo/server.mojo -o servers/nats-mojo/nats-mojo",
    "nats:mojo:start": "servers/nats-mojo/nats-mojo",
    "rust:nats:build": "npm run nats:rust:build",
    "rust:nats:test": "npm run nats:rust:test",
    "rust:nats:wasm": "npm run nats:rust:wasm"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/suissa/universal-queues.git"
  },
  "keywords": [
    "mensageria",
    "rabbitmq",
    "kafka",
    "factory",
    "queues",
    "event-driven",
    "microservices"
  ],
  "author": "Suissa",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "amqplib": "^0.10.8",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
